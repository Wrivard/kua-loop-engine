# kua-loop-engine — modèle de secrets (doc 13-SECURITY-BUDGETS.md)
# En prod : copié vers /srv/kua/.env (chmod 600, propriétaire kua-engine), JAMAIS commité.
# Le Runner n'injecte dans l'environnement d'un run QUE ce que la façade exige.

# --- Supabase (source de vérité partagée VPS + UI) ---
# URL du projet (https://<ref>.supabase.co)
SUPABASE_URL=
# Clé service_role (backend uniquement — bypass RLS). JAMAIS côté client/UI.
SUPABASE_SERVICE_ROLE_KEY=
# Connexion SQL directe (psycopg / migrations) — postgresql://...:<pwd>@...:5432/postgres
SUPABASE_DB_URL=

# --- Trigger Gateway ---
# Secret partagé pour vérifier la signature HMAC des webhooks Sentry.
SENTRY_WEBHOOK_SECRET=
# Bearer token pour /internal/* (Hermes, CLI) — réseau local.
INTERNAL_TOKEN=

# --- Hermes / Discord (renseigné via `hermes setup`, pas ici en général) ---
DISCORD_BOT_TOKEN=

# --- GitHub (push / PR draft par le Runner) — PAT fine-grained, scope minimal ---
GITHUB_TOKEN=

# --- Runner ---
MAX_CONCURRENT_RUNS=2
KUA_CHECKOUTS_DIR=/srv/kua/checkouts
KUA_LOG_DIR=/var/log/kua

# --- Auth Claude Code ---
# Le Runner lit l'auth depuis l'environnement (plan Max 20x par défaut, doc 02 ADR 6).
# Pour basculer sur une clé API dédiée : décommenter et renseigner.
# ANTHROPIC_API_KEY=
