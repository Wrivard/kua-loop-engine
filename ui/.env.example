# UI kua-loop-engine — variables PUBLIQUES uniquement (préfixe NEXT_PUBLIC_).
# Copier en `.env.local` pour le dev. Sur Vercel : les déclarer dans
# Project Settings > Environment Variables (Production + Preview).
#
# JAMAIS de service_role ni de secret backend ici : tout NEXT_PUBLIC_* est
# exposé au navigateur. Le client n'utilise que la clé anon/publishable.

# URL du projet Supabase (https://<ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clé "anon"/"publishable" — Dashboard Supabase > Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sans ces 2 variables, l'UI démarre en MODE PREVIEW (données de démo, sans auth).
# Les renseigner bascule automatiquement sur le live + l'authentification.
