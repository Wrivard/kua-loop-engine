# Caddy — reverse proxy TLS pour le Trigger Gateway (doc 05)
# Expose le gateway (127.0.0.1:8000) sous https://hooks.kua.quebec.
#
# PRÉREQUIS (action humaine — hors du périmètre de l'agent) :
#   1. DNS : un enregistrement A  hooks.kua.quebec → IP publique du VPS.
#   2. Firewall : ouvrir les ports 80 et 443 dans ufw (le TLS auto Let's Encrypt
#      en a besoin). L'agent NE touche PAS au firewall.
# Tant que ces deux conditions ne sont pas réunies, Caddy ne peut pas obtenir
# de certificat — c'est normal.

hooks.kua.quebec {
	encode gzip
	reverse_proxy 127.0.0.1:8000
	log {
		output file /var/log/caddy/hooks.kua.quebec.log
	}
}

# Engine public (depuis Vercel) — HTTPS → gateway (8000) + bridge MCP (8001).
# PRÉREQUIS humains (hors agent) : DNS A engine.kua.quebec → IP VPS ; ports 80/443
# ouverts (TLS Let's Encrypt).
# Sécurité : /health est public (aucun secret) ; /internal/* exige le bearer
# INTERNAL_TOKEN (gateway) ; le WS /mcp-bridge exige un token court-terme émis par la
# route Next /api/mcp-bridge/token (secret long-terme côté serveur).
engine.kua.quebec {
	encode gzip
	# WS du wizard MCP → process bridge DÉDIÉ (8001, kua-mcp-bridge.service ; isole les PTY).
	@bridge path /mcp-bridge*
	reverse_proxy @bridge 127.0.0.1:8001
	# Tout le reste (/health, /internal/*) → gateway (8000). Caddy gère l'Upgrade WS nativement.
	reverse_proxy 127.0.0.1:8000
	log {
		output file /var/log/caddy/engine.kua.quebec.log
	}
}
